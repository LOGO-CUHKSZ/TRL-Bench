# API Tokens Configuration
# Copy this file to .env and fill in your tokens

# Socrata App Token (optional but recommended)
# Get it from: https://dev.socrata.com/
# Increases rate limit from 1K to 50K requests/day
SOCRATA_APP_TOKEN=

# CKAN API Key (optional)
# Get it from your CKAN portal (e.g., https://ckan.publishing.service.gov.uk/)
# Provides better rate limits for CKAN downloads
CKAN_API_KEY=
